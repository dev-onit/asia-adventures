{
  "name": "asia-calendar",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --outfile=dist/index.cjs --format=cjs --external:better-sqlite3 --external:express --external:drizzle-orm --external:drizzle-orm/better-sqlite3 --external:helmet --external:express-rate-limit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "better-sqlite3": "^9.0.0",
    "drizzle-orm": "^0.29.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/leaflet": "^1.9.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.20.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
